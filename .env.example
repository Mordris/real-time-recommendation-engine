# .env.example
# This file centralizes configuration for Docker Compose and our applications.
# Copy this file to .env and customize the values as needed.
# Ensure to keep sensitive information secure and not commit .env to version control.

# --- Docker Compose Project Name ---
COMPOSE_PROJECT_NAME=nebula

# --- PostgreSQL Configuration ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=nebula_db

# --- MinIO Configuration ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Redpanda/Kafka Topics ---
KAFKA_INTERACTIONS_TOPIC=user_interactions